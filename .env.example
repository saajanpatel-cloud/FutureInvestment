# Copy to `.env` in this repo root and fill values. Loaded by fi_finnhub_context.py (python-dotenv).
# Never commit `.env`.
#
# --- Primary fundamentals & prices: Yahoo Finance (yfinance) ---
# No API key. Installed via: pip install -r scripts/requirements.txt
# Health check: python3 scripts/fi_yahoo_health.py  (writes research/watchlists/yahoo_status.json)
# Optional probe symbol: YAHOO_PROBE_TICKER=SPY
#
# --- Market context (default refresh): Finnhub free tier ---
# Free registration: https://finnhub.io/register
# refresh_watchlists.sh runs: fi_finnhub_context.py (recommendation, insider MSPR, news count, earnings)
# Note: Finnhub /stock/social-sentiment is premium (403 on free tier) — not used.
FINNHUB_API_KEY=

# --- Legacy fi_sentiment.py reddit_x (optional; not called by refresh) ---
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=FutureInvestmentSentimentBot/0.1 by YourRedditUsername
TWITTER_BEARER_TOKEN=
